# Digital Spotter — Raspberry Pi Environment Variables
#
# HOW TO USE:
#   1. Copy this file to .env  (cp .env.example .env)
#   2. Fill in your real values
#   3. .env is in .gitignore — it will never be committed to git
#
# Then either:
#   a) Load manually before running: source .env && python3 scripts/...
#   b) Or use python-dotenv (pip install python-dotenv) — already integrated
#
# WHERE TO GET THESE:
#   HiveMQ: hivemq.com → Cloud → Your Cluster → Credentials tab

# ─── HiveMQ Cloud ─────────────────────────────────────────────────────────────
DS_MQTT_BROKER=96182a090d0445939a3976c3d0334f22.s1.eu.hivemq.cloud
DS_MQTT_PORT=8883
DS_MQTT_USERNAME=DigitalSpotter
DS_MQTT_PASSWORD=2002B01mw26#
DS_MQTT_ENABLED=true

# ─── GPIO Hardware ────────────────────────────────────────────────────────────
DS_BUZZER_PIN=18
DS_BUZZER_ENABLED=true
DS_BUZZER_FREQ=2500

DS_RGB_PIN_R=17
DS_RGB_PIN_G=27
DS_RGB_PIN_B=22
DS_RGB_ENABLED=true
DS_RGB_COMMON_ANODE=false

# ─── Inference ────────────────────────────────────────────────────────────────
DS_LOG_LEVEL=INFO
